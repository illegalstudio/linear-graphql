# Required for commands that call Linear.
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Defaults to the public Linear GraphQL endpoint.
LINEAR_API_URL=https://api.linear.app/graphql

# Optional defaults used by create/update commands when a team or project is omitted.
LINEAR_DEFAULT_TEAM=ENG
LINEAR_DEFAULT_PROJECT=

# Required only for /hooks/linear signature verification.
LINEAR_WEBHOOK_SECRET=

# Optional bearer token for local HTTP API routes other than /health and /hooks/linear.
LINEAR_LOCAL_BEARER_TOKEN=

# Local HTTP server.
LINEAR_HTTP_HOST=127.0.0.1
LINEAR_HTTP_PORT=8787

# Local persistent queue. Relative paths are resolved from the project working directory.
LINEAR_QUEUE_FILE=.linear-tool/queue.jsonl

# Runtime tuning.
LINEAR_LOG_LEVEL=info
LINEAR_REQUEST_TIMEOUT_MS=15000
LINEAR_MAX_RETRIES=3
LINEAR_CACHE_TTL_MS=300000
